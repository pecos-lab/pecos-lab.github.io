---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = allPosts.slice(0, 3);
---

<Layout title="Home">
  <main>

    <!-- ══ HERO ══ -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">Developer Blog</div>
        <h1 class="hero-title">
          Where code meets<br />
          <span class="gradient-text">craft.</span>
        </h1>
        <p class="hero-sub">
          Engineering deep dives, sharp opinions, and things I wish I'd known earlier.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn-primary">Read the blog</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">{allPosts.length}</span>
            <span class="stat-label">Articles</span>
          </div>
          <div class="stat-sep"></div>
          <div class="stat">
            <span class="stat-num">∞</span>
            <span class="stat-label">Curiosity</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ RECENT POSTS ══ -->
    {posts.length > 0 && (
      <section class="recent">
        <div class="section-inner">
          <div class="section-head">
            <h2 class="section-title">Latest</h2>
            <a href="/blog" class="section-all">View all →</a>
          </div>
          <div class="cards">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="card">
                <div class="card-meta">
                  <time>{post.data.date.toLocaleDateString('ko-KR')}</time>
                  {post.data.tags?.map(t => <span class="tag">{t}</span>)}
                </div>
                <h3 class="card-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="card-desc">{post.data.description}</p>
                )}
                <span class="card-cta">Read more →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
  main { position: relative; z-index: 1; }

  /* ── HERO ── */
  .hero {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6rem 2rem;
  }

  .hero-inner {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: var(--glass);
    border: 1px solid var(--border-2);
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--sub);
    backdrop-filter: blur(8px);
  }

  .hero-badge::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--blue);
    box-shadow: 0 0 8px var(--blue);
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text);
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--muted);
    font-weight: 300;
    max-width: 480px;
  }

  .hero-actions { display: flex; gap: 1rem; }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.75rem;
    background: var(--blue);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 980px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 0 0 rgba(41, 151, 255, 0);
  }

  .btn-primary:hover {
    background: #0a84ff;
    transform: scale(1.02);
    box-shadow: 0 0 24px rgba(41, 151, 255, 0.35);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .stat-num {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 300;
  }

  .stat-sep {
    width: 1px;
    height: 2.5rem;
    background: var(--border);
  }

  /* ── RECENT ── */
  .recent {
    padding: 5rem 2rem 8rem;
  }

  .section-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  .section-all {
    font-size: 0.875rem;
    color: var(--blue);
    transition: opacity 0.2s;
  }

  .section-all:hover { opacity: 0.75; }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 2rem;
    background: var(--glass);
    backdrop-filter: blur(12px);
    transition: background 0.25s;
  }

  .card:hover { background: var(--glass-hover); }

  .card:hover .card-cta { color: var(--blue); }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .card-meta time {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .tag {
    font-size: 0.72rem;
    color: var(--blue);
    background: var(--blue-dim);
    padding: 0.1rem 0.6rem;
    border-radius: 999px;
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.3;
    color: var(--text);
    flex: 1;
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 300;
  }

  .card-cta {
    font-size: 0.8rem;
    color: var(--sub);
    transition: color 0.2s;
    margin-top: auto;
  }
</style>
