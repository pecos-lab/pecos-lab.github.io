---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="HOME">
  <main>
    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">DEVELOPER BLOG</div>
        <h1 class="hero-title">
          PECOS<br /><span>LAB</span>
        </h1>
        <p class="hero-sub">Engineering notes. Deep dives. Built to last.</p>
        <a href="/blog" class="btn-primary">VIEW ALL POSTS</a>
      </div>
      <div class="hero-stripe"></div>
    </section>

    <!-- RECENT POSTS -->
    {posts.length > 0 && (
      <section class="recent">
        <div class="section-inner">
          <div class="section-header">
            <span class="section-label">LATEST</span>
            <a href="/blog" class="section-link">ALL POSTS →</a>
          </div>
          <div class="post-grid">
            {posts.map((post, i) => (
              <a href={`/blog/${post.id}`} class={`post-card ${i === 0 ? 'featured' : ''}`}>
                <div class="card-inner">
                  <div class="card-meta">
                    <time>{post.data.date.toLocaleDateString('ko-KR')}</time>
                    {post.data.tags && post.data.tags.length > 0 && (
                      <span class="tag">{post.data.tags[0]}</span>
                    )}
                  </div>
                  <h2 class="card-title">{post.data.title}</h2>
                  {post.data.description && (
                    <p class="card-desc">{post.data.description}</p>
                  )}
                  <span class="card-cta">READ MORE →</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 80% 50%, rgba(213, 0, 28, 0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 80% at 10% 50%, rgba(213, 0, 28, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 6rem 2rem;
    width: 100%;
  }

  .hero-eyebrow {
    font-family: var(--font-head);
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    color: var(--red);
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-head);
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.02em;
    color: var(--white);
    margin-bottom: 2rem;
  }

  .hero-title span {
    color: var(--red);
    -webkit-text-stroke: 2px var(--red);
    color: transparent;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--silver);
    margin-bottom: 3rem;
    max-width: 400px;
    line-height: 1.6;
  }

  .btn-primary {
    display: inline-block;
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    padding: 1rem 2.5rem;
    background: var(--red);
    color: #fff;
    transition: background 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    background: #ff0021;
    transform: translateY(-2px);
  }

  .hero-stripe {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: var(--red);
  }

  /* RECENT */
  .recent {
    padding: 6rem 0;
  }

  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 3rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--red);
  }

  .section-link {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    color: var(--silver);
    transition: color 0.2s;
  }

  .section-link:hover {
    color: var(--white);
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
  }

  .post-card {
    background: var(--black);
    display: block;
    transition: background 0.2s;
  }

  .post-card:hover {
    background: var(--card);
  }

  .post-card:hover .card-cta {
    color: var(--red);
  }

  .card-inner {
    padding: 2rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .card-meta time {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: var(--muted);
  }

  .tag {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--red);
    border: 1px solid var(--red);
    padding: 0.1rem 0.5rem;
  }

  .card-title {
    font-family: var(--font-head);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--silver);
    line-height: 1.6;
    flex: 1;
  }

  .card-cta {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--muted);
    transition: color 0.2s;
    margin-top: auto;
  }

  @media (max-width: 768px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
    .hero-title {
      font-size: clamp(4rem, 20vw, 8rem);
    }
  }
</style>
