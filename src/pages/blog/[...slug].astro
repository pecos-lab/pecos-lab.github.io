---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const readingTime = Math.max(1, Math.round((post.body ?? '').trim().split(/\s+/).length / 200));
---

<Layout title={post.data.title}>
  <div class="progress-bar" id="progress"></div>

  <main>
    <!-- ── HERO ── -->
    <section class="article-hero">
      <div class="hero-inner">
        <a href="/blog" class="back">← Blog</a>

        <div class="meta">
          <time>{post.data.date.toLocaleDateString('ko-KR')}</time>
          <span class="meta-sep">·</span>
          <span>{readingTime} min read</span>
          {post.data.tags?.map(t => (
            <>
              <span class="meta-sep">·</span>
              <span class="tag">{t}</span>
            </>
          ))}
        </div>

        <h1>{post.data.title}</h1>

        {post.data.description && (
          <p class="article-desc">{post.data.description}</p>
        )}
      </div>
    </section>

    <!-- ── CONTENT ── -->
    <div class="article-wrap">
      <article class="prose">
        <Content />
      </article>
    </div>

    <!-- ── BOTTOM NAV ── -->
    <div class="article-nav">
      <a href="/blog" class="nav-back">← All articles</a>
      <button id="topBtn" onclick="window.scrollTo({top:0,behavior:'smooth'})">Back to top ↑</button>
    </div>
  </main>
</Layout>

<script>
  const bar = document.getElementById('progress') as HTMLElement;
  window.addEventListener('scroll', () => {
    const d = document.documentElement;
    bar.style.width = (d.scrollTop / (d.scrollHeight - d.clientHeight) * 100) + '%';
  }, { passive: true });
</script>

<style>
  /* ── progress ── */
  .progress-bar {
    position: fixed;
    top: 52px; left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue), var(--purple));
    z-index: 300;
    transition: width 0.05s linear;
  }

  main { position: relative; z-index: 1; }

  /* ── hero ── */
  .article-hero {
    padding: 5rem 2rem 4rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--blue);
    width: fit-content;
    transition: opacity 0.2s;
  }

  .back:hover { opacity: 0.7; }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .meta-sep { color: var(--border-2); }

  .tag {
    color: var(--blue);
    background: var(--blue-dim);
    padding: 0.1rem 0.6rem;
    border-radius: 999px;
    font-size: 0.72rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.1;
    color: var(--text);
  }

  .article-desc {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.65;
    font-weight: 300;
    padding-left: 1.25rem;
    border-left: 2px solid;
    border-image: linear-gradient(to bottom, var(--blue), var(--purple)) 1;
  }

  /* ── content ── */
  .article-wrap {
    padding: 4rem 2rem 6rem;
  }

  .prose {
    max-width: 720px;
    margin: 0 auto;
  }

  /* ── markdown ── */
  .prose :global(h1),
  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.2;
    color: var(--text);
    margin: 2.5rem 0 0.75rem;
  }

  .prose :global(h2) { font-size: 1.6rem; }
  .prose :global(h3) { font-size: 1.3rem; color: #d1d1d6; }

  .prose :global(p) {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #aeaeb2;
    margin: 1.25rem 0;
    font-weight: 300;
  }

  .prose :global(strong) { color: var(--text); font-weight: 600; }

  .prose :global(a) {
    color: var(--blue);
    text-decoration: underline;
    text-decoration-color: rgba(41, 151, 255, 0.35);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .prose :global(a:hover) { text-decoration-color: var(--blue); }

  .prose :global(code) {
    font-family: var(--mono);
    font-size: 0.83em;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--border);
    padding: 0.15em 0.45em;
    border-radius: 5px;
    color: #e5c07b;
  }

  .prose :global(pre) {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
    backdrop-filter: blur(8px);
  }

  .prose :global(pre code) {
    font-family: var(--mono);
    background: none;
    border: none;
    padding: 0;
    color: #abb2bf;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 1.25rem 0;
  }

  .prose :global(li) {
    color: #aeaeb2;
    line-height: 1.8;
    font-size: 1.05rem;
    margin: 0.3rem 0;
    font-weight: 300;
  }

  .prose :global(blockquote) {
    margin: 2rem 0;
    padding: 1.25rem 1.5rem;
    background: var(--glass);
    border-radius: 10px;
    border-left: 2px solid;
    border-image: linear-gradient(to bottom, var(--blue), var(--purple)) 1;
    backdrop-filter: blur(8px);
  }

  .prose :global(blockquote p) {
    color: var(--sub);
    font-style: italic;
    margin: 0;
  }

  .prose :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-2), transparent);
    margin: 3rem 0;
  }

  .prose :global(img) {
    max-width: 100%;
    border-radius: 12px;
    border: 1px solid var(--border);
    display: block;
    margin: 2rem auto;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }

  .prose :global(th) {
    text-align: left;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border-2);
    color: var(--sub);
    font-weight: 500;
    font-size: 0.8rem;
  }

  .prose :global(td) {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    color: #aeaeb2;
    font-weight: 300;
    line-height: 1.6;
  }

  .prose :global(tr:hover td) { background: var(--glass); }

  /* ── article nav ── */
  .article-nav {
    border-top: 1px solid var(--border);
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 720px;
    margin: 0 auto;
  }

  .nav-back {
    font-size: 0.85rem;
    color: var(--blue);
    transition: opacity 0.2s;
  }

  .nav-back:hover { opacity: 0.7; }

  #topBtn {
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--glass);
    border: 1px solid var(--border);
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    cursor: pointer;
    font-family: var(--font);
    transition: color 0.2s, border-color 0.2s;
    backdrop-filter: blur(8px);
  }

  #topBtn:hover { color: var(--text); border-color: var(--border-2); }
</style>
