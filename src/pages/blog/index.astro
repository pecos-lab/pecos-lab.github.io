---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function readingTime(body: string) {
  return Math.max(1, Math.round((body ?? '').trim().split(/\s+/).length / 200));
}
---

<Layout title="Blog">
  <main>

    <section class="page-header">
      <div class="inner">
        <h1>Blog<span class="dot">.</span></h1>
        <p class="header-sub">{posts.length} articles on engineering, tools, and ideas.</p>
      </div>
    </section>

    <section class="list-section">
      <div class="inner">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="row">
            <div class="row-body">
              <div class="row-meta">
                <time>{post.data.date.toLocaleDateString('ko-KR')}</time>
                <span class="meta-dot">·</span>
                <span class="read-time">{readingTime(post.body ?? '')} min read</span>
                {post.data.tags?.map(t => <span class="tag">{t}</span>)}
              </div>
              <h2 class="row-title">{post.data.title}</h2>
              {post.data.description && <p class="row-desc">{post.data.description}</p>}
            </div>
            <span class="row-arrow">→</span>
          </a>
        ))}
      </div>
    </section>

  </main>
</Layout>

<style>
  main { position: relative; z-index: 1; }

  .inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── HEADER ── */
  .page-header {
    padding: 6rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .dot {
    background: linear-gradient(135deg, var(--blue), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .header-sub {
    font-size: 1rem;
    color: var(--muted);
    font-weight: 300;
  }

  /* ── LIST ── */
  .list-section { padding: 0 0 8rem; }

  .row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
    border-radius: 4px;
    position: relative;
  }

  .row::after {
    content: '';
    position: absolute;
    bottom: -1px; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--blue), var(--purple));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .row:hover::after { opacity: 1; }
  .row:hover .row-title { color: var(--text); }
  .row:hover .row-arrow { color: var(--blue); transform: translateX(4px); }

  .row-body { flex: 1; display: flex; flex-direction: column; gap: 0.5rem; }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .row-meta time,
  .read-time {
    font-size: 0.78rem;
    color: var(--muted);
  }

  .meta-dot { color: var(--border-2); }

  .tag {
    font-size: 0.72rem;
    color: var(--blue);
    background: var(--blue-dim);
    padding: 0.1rem 0.6rem;
    border-radius: 999px;
  }

  .row-title {
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.3;
    color: #d1d1d6;
    transition: color 0.2s;
  }

  .row-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 300;
  }

  .row-arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: color 0.2s, transform 0.25s;
    flex-shrink: 0;
  }
</style>
