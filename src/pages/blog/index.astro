---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="BLOG">
  <main>
    <section class="header">
      <div class="inner">
        <span class="eyebrow">JOURNAL</span>
        <h1>BLOG</h1>
        <p>{posts.length} POSTS</p>
      </div>
    </section>

    <section class="list">
      <div class="inner">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="row">
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <div class="row-content">
              <h2>{post.data.title}</h2>
              {post.data.description && <p>{post.data.description}</p>}
            </div>
            <div class="row-right">
              {post.data.tags && post.data.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
              <time>{post.data.date.toLocaleDateString('ko-KR')}</time>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    padding: 5rem 0 3rem;
  }

  .inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .eyebrow {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.3em;
    color: var(--red);
    display: block;
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-head);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .header p {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: var(--muted);
  }

  .list {
    padding: 0 0 6rem;
  }

  .list .inner {
    padding-top: 0;
  }

  .row {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }

  .row:hover {
    background: var(--card);
    padding-left: 1rem;
    padding-right: 1rem;
    margin: 0 -1rem;
  }

  .row:hover .arrow {
    color: var(--red);
    transform: translateX(4px);
  }

  .num {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    align-self: start;
    padding-top: 0.3rem;
  }

  .row-content h2 {
    font-family: var(--font-head);
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .row-content p {
    font-size: 0.875rem;
    color: var(--silver);
    line-height: 1.5;
  }

  .row-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    min-width: 120px;
  }

  .tag {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--red);
    border: 1px solid var(--red);
    padding: 0.15rem 0.5rem;
  }

  time {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .arrow {
    font-size: 1rem;
    color: var(--muted);
    transition: color 0.2s, transform 0.2s;
  }

  @media (max-width: 600px) {
    .row {
      grid-template-columns: 2rem 1fr;
    }
    .row-right {
      display: none;
    }
  }
</style>
