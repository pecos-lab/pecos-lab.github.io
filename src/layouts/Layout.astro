---
interface Props {
  title?: string;
}
const { title = 'HOME' } = Astro.props;
---
<!doctype html>
<html lang="ko" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — PECOS LAB</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      // apply saved theme before paint to prevent flash
      const saved = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', saved);
    </script>
  </head>
  <body>
    <div class="bg-orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <header>
      <nav>
        <a href="/" class="logo">pecos<span>lab</span></a>
        <div class="nav-right">
          <ul>
            <li><a href="/blog" class="nav-link">Blog</a></li>
          </ul>
          <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
            <span class="icon-sun">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
              </svg>
            </span>
            <span class="icon-moon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
              </svg>
            </span>
          </button>
        </div>
      </nav>
    </header>

    <slot />

    <footer>
      <div class="footer-inner">
        <span class="footer-logo">pecos<span>lab</span></span>
        <span class="footer-copy">© {new Date().getFullYear()} All rights reserved.</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const toggle = document.getElementById('themeToggle')!;
  const html   = document.documentElement;

  toggle.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style is:global>
  /* ══════════════════════════════
     DARK THEME (default)
  ══════════════════════════════ */
  :root,
  [data-theme="dark"] {
    --blue:         #2997ff;
    --blue-dim:     rgba(41, 151, 255, 0.10);
    --blue-glow:    rgba(41, 151, 255, 0.18);
    --purple:       #bf5af2;
    --purple-dim:   rgba(191, 90, 242, 0.10);

    --bg:           #000000;
    --bg-2:         #0a0a0a;
    --glass:        rgba(255, 255, 255, 0.03);
    --glass-hover:  rgba(255, 255, 255, 0.06);
    --border:       rgba(255, 255, 255, 0.07);
    --border-2:     rgba(255, 255, 255, 0.12);

    --text:         #f5f5f7;
    --text-2:       #d1d1d6;
    --sub:          #aeaeb2;
    --muted:        #6e6e73;

    --orb-1-color:  #0d2a55;
    --orb-2-color:  #2a0d4a;
    --orb-3-color:  #0a2a40;
    --orb-opacity:  0.55;

    --nav-bg:       rgba(0, 0, 0, 0.75);
    --nav-blur:     12px;
    --code-bg:      rgba(255, 255, 255, 0.05);
    --code-color:   #e5c07b;
    --pre-bg:       rgba(255, 255, 255, 0.03);

    color-scheme: dark;
  }

  /* ══════════════════════════════
     LIGHT THEME
  ══════════════════════════════ */
  [data-theme="light"] {
    --blue:         #0071e3;
    --blue-dim:     rgba(0, 113, 227, 0.08);
    --blue-glow:    rgba(0, 113, 227, 0.14);
    --purple:       #8944ab;
    --purple-dim:   rgba(137, 68, 171, 0.08);

    --bg:           #f5f5f7;
    --bg-2:         #ffffff;
    --glass:        rgba(255, 255, 255, 0.55);
    --glass-hover:  rgba(255, 255, 255, 0.80);
    --border:       rgba(0, 0, 0, 0.06);
    --border-2:     rgba(0, 0, 0, 0.10);

    --text:         #1d1d1f;
    --text-2:       #3a3a3c;
    --sub:          #6e6e73;
    --muted:        #8e8e93;

    --orb-1-color:  #c5d8f5;
    --orb-2-color:  #dac5f5;
    --orb-3-color:  #c5e8f5;
    --orb-opacity:  0.6;

    --nav-bg:       rgba(245, 245, 247, 0.78);
    --nav-blur:     12px;
    --code-bg:      rgba(0, 0, 0, 0.04);
    --code-color:   #8944ab;
    --pre-bg:       rgba(0, 0, 0, 0.03);

    color-scheme: light;
  }

  /* ══════════════════════════════
     BASE
  ══════════════════════════════ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    transition: background 0.3s, color 0.3s;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; }

  /* ══════════════════════════════
     AMBIENT ORBS
  ══════════════════════════════ */
  .bg-orbs {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: var(--orb-opacity);
    transition: background 0.4s;
  }

  .orb-1 {
    width: 650px; height: 650px;
    top: -220px; left: -180px;
    background: var(--orb-1-color);
  }

  .orb-2 {
    width: 500px; height: 500px;
    top: 25%; right: -160px;
    background: var(--orb-2-color);
  }

  .orb-3 {
    width: 400px; height: 400px;
    bottom: 5%; left: 25%;
    background: var(--orb-3-color);
  }

  /* ══════════════════════════════
     HEADER
  ══════════════════════════════ */
  header {
    position: sticky;
    top: 0;
    z-index: 200;
    background: var(--nav-bg);
    backdrop-filter: blur(var(--nav-blur));
    -webkit-backdrop-filter: blur(var(--nav-blur));
    border-bottom: 1px solid var(--border);
    transition: background 0.3s, border-color 0.3s;
  }

  nav {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    transition: color 0.2s;
  }

  .logo span {
    background: linear-gradient(135deg, var(--blue), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  nav ul { list-style: none; display: flex; gap: 2rem; }

  .nav-link {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-link:hover { color: var(--text); }

  /* ── theme toggle ── */
  .theme-toggle {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--border-2);
    background: var(--glass);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--muted);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    background: var(--glass-hover);
    color: var(--text);
    border-color: var(--border-2);
  }

  [data-theme="dark"] .icon-sun  { display: flex; }
  [data-theme="dark"] .icon-moon { display: none; }
  [data-theme="light"] .icon-sun  { display: none; }
  [data-theme="light"] .icon-moon { display: flex; }

  /* ══════════════════════════════
     FOOTER
  ══════════════════════════════ */
  footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 2rem;
    position: relative;
    z-index: 1;
    transition: border-color 0.3s;
  }

  .footer-inner {
    max-width: 1080px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-logo {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .footer-logo span {
    background: linear-gradient(135deg, var(--blue), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .footer-copy {
    font-size: 0.78rem;
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .footer-copy { display: none; }
  }
</style>
